@inherits Miko.Components.LayoutComponentBase

<div class="layout">
    <div class="sidebar">
        <h2>Miko Demo</h2>
        <div class="nav-item">
            <span>Button</span>
        </div>
        <div class="nav-item">
            <span>Form</span>
        </div>
        <div class="nav-item">
            <span>List</span>
        </div>
        <div class="nav-item">
            <span>Icon</span>
        </div>
        <div class="nav-item">
            <span>Table</span>
        </div>
    </div>
    <div class="main-content">
        @Body
    </div>
</div>

@code {
    public static Miko.Styling.StyleSheet CreateLayoutStyleSheet()
    {
        return new Miko.Styling.StyleSheet
        {
            Rules = new List<Miko.Styling.StyleRule>
            {
                new()
                {
                    Selector = new Miko.Styling.Selectors.ClassSelector("layout"),
                    Style = new Miko.Styling.Style
                    {
                        Display = Miko.Common.Display.Flex,
                        Width = Miko.Common.Length.Percent(100),
                        Height = Miko.Common.Length.Percent(100),
                    }
                },
                new()
                {
                    Selector = new Miko.Styling.Selectors.ClassSelector("sidebar"),
                    Style = new Miko.Styling.Style
                    {
                        Width = Miko.Common.Length.Px(200),
                        Height = Miko.Common.Length.Percent(100),
                        Padding = Miko.Common.Length.Px(16),
                        BackgroundColor = Miko.Common.Color.FromRgb(52, 58, 64),
                        Color = Miko.Common.Color.White,
                    }
                },
                new()
                {
                    Selector = new Miko.Styling.Selectors.ClassSelector("main-content"),
                    Style = new Miko.Styling.Style
                    {
                        FlexGrow = 1,
                        Padding = Miko.Common.Length.Px(16),
                        OverflowY = Miko.Common.Overflow.Scroll,
                    }
                },
                new()
                {
                    Selector = new Miko.Styling.Selectors.ClassSelector("nav-item"),
                    Style = new Miko.Styling.Style
                    {
                        Padding = Miko.Common.Length.Px(10),
                        MarginBottom = Miko.Common.Length.Px(4),
                        Color = Miko.Common.Color.White,
                    }
                },
            }
        };
    }
}
