@page "/button"
@namespace MikoApp1.Razor.Components

<div class="container">
    <h1>Button Examples</h1>

    <h2>Standard Buttons</h2>

    <div class="row">
        <Button Variant="primary">Primary</Button>
        <Button Variant="secondary">Secondary</Button>
        <Button Variant="success">Success</Button>
        <Button Variant="danger">Danger</Button>
        <Button Variant="warning">Warning</Button>
        <Button Variant="info">Info</Button>
        <Button Variant="light">Light</Button>
        <Button Variant="dark">Dark</Button>
    </div>

    <h2>Disabled Buttons</h2>
    <div class="row">
        <Button Variant="primary" Disabled="true">Disabled Primary</Button>
        <Button Variant="secondary" Disabled="true">Disabled Secondary</Button>
    </div>

    <h2>Interactive Buttons</h2>
    <div class="row">
        <Button Variant="success" OnClick="HandleClick">Click Me!</Button>
        <Button Variant="danger" OnClick="HandleClick">Delete</Button>
    </div>

    @if (_clickCount > 0)
    {
        <p>Button clicked @_clickCount times</p>
    }
</div>

@code {
    private int _clickCount = 0;

    private void HandleClick()
    {
        _clickCount++;
    }
}

