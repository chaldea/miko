    <h2>Contextual Classes</h2>
    <table class="table">
        <thead>
            <tr>
                <th>Class</th>
                <th>Heading</th>
                <th>Heading</th>
            </tr>
        </thead>
        <tbody>
            <tr class="table-default">
                <th>Default</th>
