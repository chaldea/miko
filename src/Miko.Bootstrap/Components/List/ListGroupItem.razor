@namespace Miko.Bootstrap.Components
<div class="@_cssClass">@ChildContent</div>

@code {
    private string _cssClass = "list-group-item";
    [Parameter] public bool Active { get; set; }
    [Parameter] public bool Disabled { get; set; }

    protected override void OnParametersSet()
    {
        var classes = new List<string> { "list-group-item" };
        if (Active) classes.Add("active");
        if (Disabled) classes.Add("disabled");
        _cssClass = string.Join(" ", classes);
    }
}
