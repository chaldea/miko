@namespace Miko.Bootstrap.Components
<div class="@_cssClass">
    @ChildContent
</div>

@code {
    private string _cssClass = "col";

    [Parameter] public int Width { get; set; }
    [Parameter] public bool Auto { get; set; }
    [Parameter] public int Offset { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        var classes = new List<string>();

        if (Auto)
            classes.Add("col-auto");
        else if (Width > 0 && Width <= 12)
            classes.Add($"col-{Width}");
        else
            classes.Add("col");

        if (Offset > 0 && Offset <= 11)
            classes.Add($"offset-{Offset}");

        _cssClass = string.Join(" ", classes);
    }
}
