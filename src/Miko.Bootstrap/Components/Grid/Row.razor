@namespace Miko.Bootstrap.Components
<div class="@_cssClass">
    @ChildContent
</div>

@code {
    private string _cssClass = "row";

    [Parameter] public string Gutter { get; set; } = "";

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        _cssClass = string.IsNullOrEmpty(Gutter) ? "row" : $"row {Gutter}";
    }
}
