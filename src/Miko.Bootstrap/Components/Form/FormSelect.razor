@namespace Miko.Bootstrap.Components
<select class="@_cssClass" disabled="@Disabled">
    @ChildContent
</select>

@code {
    private string _cssClass = "form-select";

    [Parameter] public string Size { get; set; } = "";
    [Parameter] public bool Disabled { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        _cssClass = string.IsNullOrEmpty(Size) ? "form-select" : $"form-select form-select-{Size}";
    }
}
