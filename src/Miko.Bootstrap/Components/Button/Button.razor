@namespace Miko.Bootstrap.Components
<button class="@_cssClass" disabled="@Disabled" @onclick="HandleClick">
    @ChildContent
</button>

@code {
    private string _cssClass = "btn";

    /// <summary>
    /// Button variant (primary, secondary, success, danger, warning, info, light, dark)
    /// </summary>
    [Parameter] public string Variant { get; set; } = "primary";

    /// <summary>
    /// Whether the button is disabled
    /// </summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>
    /// Synchronous click event callback.
    /// </summary>
    [Parameter] public Action? OnClick { get; set; }

    /// <summary>
    /// Async click event callback. If both OnClick and OnClickAsync are set, both are invoked.
    /// </summary>
    [Parameter] public Func<Task>? OnClickAsync { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        _cssClass = $"btn btn-{Variant}";
    }

    private async Task HandleClick()
    {
        if (Disabled) return;
        OnClick?.Invoke();
        if (OnClickAsync != null)
            await OnClickAsync();
    }
}
