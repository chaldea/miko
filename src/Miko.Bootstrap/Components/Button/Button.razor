@namespace Miko.Bootstrap.Components
<button class="@_cssClass" disabled="@Disabled" @onclick="HandleClickAsync">
    @ChildContent
</button>

@code {
    private string _cssClass = "btn";

    /// <summary>
    /// Button variant (primary, secondary, success, danger, warning, info, light, dark)
    /// </summary>
    [Parameter] public string Variant { get; set; } = "primary";

    /// <summary>
    /// Whether the button is disabled
    /// </summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>
    /// Click event callback. The Razor compiler will accept Action, Func&lt;Task&gt;, or
    /// another EventCallback. Both sync and async handlers are supported uniformly.
    /// </summary>
    [Parameter] public EventCallback OnClick { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        _cssClass = $"btn btn-{Variant}";
    }

    private async Task HandleClickAsync(MouseEventArgs _)
    {
        if (Disabled) return;
        await OnClick.InvokeAsync();
    }
}

}
