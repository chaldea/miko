@namespace Miko.Bootstrap.Components
<li class="nav-item">
    <button class="@_cssClass" @onclick="HandleClick">@Title</button>
</li>

@code {
    private string _cssClass = "nav-link";
    [Parameter] public string? Title { get; set; }
    [Parameter] public bool Active { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    protected override void OnParametersSet()
    {
        _cssClass = Active ? "nav-link active" : "nav-link";
    }

    private async Task HandleClick(MouseEventArgs _)
    {
        await OnClick.InvokeAsync();
    }
}
