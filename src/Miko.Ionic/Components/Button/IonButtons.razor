@namespace Miko.Ionic.Components
@inherits IonicComponentBase
<div class="@ClassMapper.Class" style="@Style">
    @ChildContent
</div>

@code {
    /// <summary>
    /// Placement within the toolbar: <c>"start"</c> (default, leading edge) or
    /// <c>"end"</c> (trailing edge). Mirrors Ionic's <c>slot</c> attribute on
    /// <c>ion-buttons</c>. Visual order follows authoring order in the toolbar markup.
    /// </summary>
    [Parameter] public string Slot { get; set; } = "start";

    protected override void OnParametersSet()
    {
        var slot = string.Equals(Slot, "end", StringComparison.OrdinalIgnoreCase) ? "end" : "start";

        ClassMapper
            .Clear()
            .Add(Class)
            .Add(Mode)
            .Add("ion-buttons")
            .Add($"buttons-{slot}");
    }
}
