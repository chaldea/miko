@namespace Miko.Ionic.Components
@inherits IonicComponentBase
<div class="@ClassMapper.Class" style="@Style" @onclick="HandleClick">
    <IonIcon Icon="@Ionicons.Menu" />
</div>

@code {
    /// <summary>Invoked when the hamburger button is clicked (typically opens the menu).</summary>
    [Parameter] public EventCallback OnClick { get; set; }

    protected override void OnParametersSet()
    {
        ClassMapper
            .Clear()
            .Add(Class)
            .Add(Mode)
            .Add("ion-menu-button");
    }

    private async Task HandleClick(MouseEventArgs _)
    {
        await OnClick.InvokeAsync();
    }
}
