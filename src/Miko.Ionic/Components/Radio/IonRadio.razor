@namespace Miko.Ionic.Components
@inherits IonicComponentBase
@using Miko.Common
@* Mirrors Ionic's <ion-radio> host structure:
   <ion-radio class="{mode} ion-radio radio-label-placement-{start|end|fixed|stacked} ...
                     [radio-checked] [radio-disabled] [radio-justify-*] [radio-alignment-*]
                     [ion-color ion-color-*]" role="radio">
     <label class="radio-wrapper" @onclick=HandleClick>   <!-- the click target -->
       <input type="radio" class="radio-native" />        <!-- hidden native control, form parity -->
       <div class="label-text-wrapper">                   <!-- slotted label; hidden when empty -->
         <slot />                                          <!-- ChildContent -->
       </div>
       <div class="native-wrapper">
         <div class="radio-icon">                          <!-- md: bordered ring; ios: bare box -->
           <div class="radio-inner"></div>                 <!-- md: filled dot revealed on check;
                                                                ios: a checkmark glyph shown on check -->
         </div>
       </div>
     </label>
   </ion-radio>
   A radio has no own Checked param — its checked state comes from the enclosing radio-group's
   selected value (Value == group's Value). HandleClick asks the group to select this value.
   md vs ios: md draws an outer ring + an inner filled circle (both styled in RadioStyles); ios has
   no ring and shows a checkmark glyph, supplied here as a template background image (tinted by the
   computed --color-checked) exactly like IonCheckbox's mark. The md styles hide that image and paint
   .radio-inner as a filled dot instead. *@
<div class="@ClassMapper.Class" style="@Style" role="radio">
    <label class="radio-wrapper" @onclick="HandleClick">
        <input type="radio" class="radio-native" />
        <div class="label-text-wrapper">
            @ChildContent
        </div>
        <div class="native-wrapper">
            <div class="radio-icon">
                <div class="radio-inner" style="@_innerStyle"></div>
            </div>
        </div>
    </label>
</div>

@code {
    /// <summary>This radio's value — its identity within a group. Required: the group's selected
    /// value is compared against this to derive the checked state.</summary>
    [Parameter] public string Value { get; set; } = string.Empty;

    /// <summary>Named palette color (Ionic <c>color</c>): <c>"primary"</c>, <c>"danger"</c>, … .
    /// Stamped as an <c>ion-color-*</c> class the stylesheet maps to the checked ring / dot.</summary>
    [Parameter] public string? Color { get; set; }

    /// <summary>If true, the user cannot interact with the radio.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>The name of the control, submitted with the form data.</summary>
    [Parameter] public string? Name { get; set; }

    /// <summary>Where the label sits relative to the radio: <c>"start"</c> (default), <c>"end"</c>,
    /// <c>"fixed"</c>, or <c>"stacked"</c>.</summary>
    [Parameter] public string LabelPlacement { get; set; } = "start";

    /// <summary>How to pack the label and radio within a line: <c>"start"</c>, <c>"end"</c>, or
    /// <c>"space-between"</c>. Setting this changes the host <c>display</c> to block.</summary>
    [Parameter] public string? Justify { get; set; }

    /// <summary>Cross-axis alignment of the label and radio: <c>"start"</c> or <c>"center"</c>.
    /// Setting this changes the host <c>display</c> to block.</summary>
    [Parameter] public string? Alignment { get; set; }

    // ChildContent (the label text, Ionic's default slot) is inherited from ComponentBase.

    /// <summary>Selection state supplied by the enclosing <see cref="IonRadioGroup"/>. When absent,
    /// the radio is never checked (Ionic radios only track selection through a group).</summary>
    [CascadingParameter] public IonRadioGroupContext? Group { get; set; }

    private Style? _innerStyle;

    /// <summary>True when this radio's value matches the group's selected value.</summary>
    public bool Checked { get; private set; }

    /// <summary>True when this radio is disabled directly or through its group.</summary>
    private bool IsDisabled => Disabled || (Group?.Disabled ?? false);

    protected override void OnParametersSet()
    {
        Checked = Group is not null && Group.IsSelected(Value);

        var placement = NormalizeToken(LabelPlacement, "start");

        ClassMapper
            .Clear()
            .Add(ClassName)
            .Add(Mode)
            .Add("ion-radio")
            .Add($"radio-label-placement-{placement}")
            .If(Checked, "radio-checked")
            .If(IsDisabled, "radio-disabled")
            .AddValue(Justify, "radio-justify-")
            .AddValue(Alignment, "radio-alignment-")
            .If(!string.IsNullOrWhiteSpace(Color), "ion-color")
            .AddColor(Color);

        // The ios checkmark glyph, supplied as a template background image so it is tinted by the
        // computed color (see RadioStyles). Only ios draws a checkmark; md paints .radio-inner as a
        // filled dot (styled entirely in RadioStyles), so no inline image is set there.
        var image = Mode == "ios" ? IconResolver.Load(Ionicons.Checkmark) : null;
        _innerStyle = image is null
            ? null
            : new Style
            {
                BackgroundImage = image,
                BackgroundSize = BackgroundSize.Contain,
                BackgroundPosition = BackgroundPosition.Center,
                BackgroundRepeat = BackgroundRepeat.NoRepeat,
            };
    }

    /// <summary>
    /// After the subtree is built, sync the hidden native control's state and hide the label wrapper
    /// when there is no slotted label content — mirrors Ionic deriving <c>label-text-wrapper-hidden</c>
    /// from an empty slot (via <c>textContent</c>).
    /// </summary>
    public override Element Build()
    {
        var root = base.Build();

        if (root.FindByClass("radio-native").FirstOrDefault() is InputElement input)
        {
            input.Type = InputType.Radio;
            input.Checked = Checked;
            if (IsDisabled) input.SetState(ElementState.Disabled);
        }

        if (root.FindByClass("label-text-wrapper").FirstOrDefault() is { } label && !HasLabelContent(label))
        {
            label.Class += " label-text-wrapper-hidden";
        }

        return root;
    }

    // A label is considered empty when it has no slotted text/elements.
    private static bool HasLabelContent(Element label)
    {
        foreach (var child in label.Children)
        {
            if (child is TextNode text && string.IsNullOrWhiteSpace(text.TextContent)) continue;
            return true;
        }
        return false;
    }

    /// <summary>
    /// Ionic's <c>onClick</c>: no-op when disabled; otherwise ask the group to select this value.
    /// The group applies the single-select / allow-empty-selection rules. A standalone radio (no
    /// group) has nothing to select into, so the click is a no-op.
    /// </summary>
    private async Task HandleClick(MouseEventArgs _)
    {
        if (IsDisabled || Group is null) return;

        await Group.RequestSelect.InvokeAsync(Value);
    }

    private static string NormalizeToken(string? value, string fallback)
        => string.IsNullOrWhiteSpace(value) ? fallback : value.ToLowerInvariant();
}
