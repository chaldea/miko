@namespace Miko.Ionic.Components
@inherits IonicComponentBase
<a class="@ClassMapper.Class" style="@Style" href="@Href" @onclick="HandleClick">
    @ChildContent
</a>

@code {
    /// <summary>Logical tab identifier (e.g. <c>"tab1"</c>).</summary>
    [Parameter] public string? Tab { get; set; }

    /// <summary>Navigation target for the tab button.</summary>
    [Parameter] public string? Href { get; set; }

    /// <summary>Whether this tab button is the currently selected one.</summary>
    [Parameter] public bool Selected { get; set; }

    /// <summary>Invoked when the tab button is clicked.</summary>
    [Parameter] public EventCallback OnClick { get; set; }

    protected override void OnParametersSet()
    {
        ClassMapper
            .Clear()
            .Add(Class)
            .Add(Mode)
            .Add("ion-tab-button")
            .If(Selected, "tab-selected");
    }

    private async Task HandleClick(MouseEventArgs _)
    {
        await OnClick.InvokeAsync();
    }
}
