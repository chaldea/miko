@namespace Miko.Ionic.Components
@inherits IonicComponentBase
<div class="@ClassMapper.Class" style="@Style">
    <div class="tabs-inner">
        @Content
    </div>
    @Bar
</div>

@code {
    /// <summary>
    /// Main content area shown above (slot="bottom") or below (slot="top") the tab bar.
    /// </summary>
    [Parameter] public RenderFragment? Content { get; set; }

    /// <summary>
    /// The tab bar (<c>ion-tab-bar</c>) holding the tab buttons.
    /// </summary>
    [Parameter] public RenderFragment? Bar { get; set; }

    protected override void OnParametersSet()
    {
        ClassMapper
            .Clear()
            .Add(ClassName)
            .Add(Mode)
            .Add("ion-tabs");
    }
}
