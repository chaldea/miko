@namespace Miko.Ionic.Components
@inherits IonicComponentBase
<div class="@ClassMapper.Class" style="@Style">
    @ChildContent
</div>

@code {
    /// <summary>Named palette color (Ionic <c>color</c>): <c>"primary"</c>, <c>"danger"</c>, ... .</summary>
    [Parameter] public string? Color { get; set; }

    /// <summary>When true, stamps the iOS translucent header marker class.</summary>
    [Parameter] public bool Translucent { get; set; }

    protected override void OnParametersSet()
    {
        ClassMapper
            .Clear()
            .Add(Class)
            .Add(Mode)
            .Add("ion-card-header")
            .Add("ion-inherit-color")
            .If(Translucent, "card-header-translucent")
            .If(!string.IsNullOrWhiteSpace(Color), "ion-color")
            .AddColor(Color);
    }
}
