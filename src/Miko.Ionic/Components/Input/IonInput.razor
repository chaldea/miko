@namespace Miko.Ionic.Components
@inherits IonicComponentBase
@using Miko.Common
@using Miko.Core
@using Miko.Core.DomElements
@using Miko.Events
@* Mirrors Ionic's <ion-input> host structure (input.tsx render()):
   <ion-input>                                   <!-- host: mode + placement + fill/shape + state classes -->
     <label class="input-wrapper">               <!-- the flex line; also the click target -->
       <div class="label-text-wrapper">          <!-- the label; display:none when empty -->
         <div class="label-text">{Label}</div>
       </div>
       <div class="native-wrapper">
         @StartSlot
         <input class="native-input" />          <!-- the native text field -->
         <button class="input-clear-icon">…</button>  <!-- clearInput && has value && !readonly && !disabled -->
         @EndSlot
       </div>
       <div class="input-highlight" />            <!-- md only, fill != outline, not in an item -->
     </label>
     <div class="input-bottom">                   <!-- only when helper/error text or counter -->
       <div class="helper-text">…</div>
       <div class="error-text">…</div>
       <div class="counter">…</div>               <!-- counter && maxlength set -->
     </div>
   </ion-input>

   Scope: the portable feature surface. Browser-only concerns from input.tsx have no Miko
   equivalent and are intentionally omitted — `debounce`, IME composition, `clearOnEdit`,
   MutationObserver validity tracking (ion-valid/ion-invalid), ARIA attribute inheritance, and
   the fill="outline" notch controller. The native value/placeholder/disabled are applied to the
   built InputElement in Build() because RenderTreeBuilder only wires `type` for a native <input>. *@
<div class="@ClassMapper.Class" style="@Style">
    <label class="input-wrapper" @onclick="HandleLabelClick">
        <div class="@_labelWrapperClass">
            @if (!string.IsNullOrEmpty(Label))
            {
                <div class="label-text">@Label</div>
            }
        </div>
        <div class="native-wrapper">
            @StartSlot
            <input class="native-input" type="@Type" @oninput="HandleInput" @onchange="HandleChange" />
            @if (ShowClearButton)
            {
                <button class="input-clear-icon" @onclick="HandleClearClick">
                    <IonIcon Icon="@_clearIcon" />
                </button>
            }
            @EndSlot
        </div>
        @if (ShowHighlight)
        {
            <div class="input-highlight"></div>
        }
    </label>
    @if (HasBottomContent)
    {
        <div class="input-bottom">
            @if (!string.IsNullOrEmpty(HelperText))
            {
                <div class="helper-text">@HelperText</div>
            }
            @if (!string.IsNullOrEmpty(ErrorText))
            {
                <div class="error-text">@ErrorText</div>
            }
            @if (ShowCounter)
            {
                <div class="counter">@_counterText</div>
            }
        </div>
    }
</div>

@code {
    /// <summary>Named palette color (Ionic <c>color</c>): <c>"primary"</c>, <c>"danger"</c>, … .
    /// Stamped as an <c>ion-color-*</c> class the stylesheet maps to the focus highlight tint.</summary>
    [Parameter] public string? Color { get; set; }

    /// <summary>The value of the input.</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Raised (with the new value) as the user types (two-way binding support).</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>Raised each time the user modifies the value (Ionic <c>ionInput</c>).</summary>
    [Parameter] public EventCallback<string?> OnInput { get; set; }

    /// <summary>Raised when the value change is committed, i.e. on the native change (Ionic <c>ionChange</c>).</summary>
    [Parameter] public EventCallback<string?> OnChange { get; set; }

    /// <summary>Instructional text shown before the input has a value.</summary>
    [Parameter] public string? Placeholder { get; set; }

    /// <summary>The visible plaintext label associated with the input.</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>Where the label sits relative to the input: <c>"start"</c> (default), <c>"end"</c>,
    /// <c>"fixed"</c>, <c>"stacked"</c>, or <c>"floating"</c>.</summary>
    [Parameter] public string LabelPlacement { get; set; } = "start";

    /// <summary>The native control type (<c>"text"</c>, <c>"password"</c>, <c>"search"</c>, …).
    /// Types with no Miko equivalent (email/tel/url/number) fall back to a text field.</summary>
    [Parameter] public string Type { get; set; } = "text";

    /// <summary>The fill style: <c>"solid"</c> (filled) or <c>"outline"</c> (bordered).</summary>
    [Parameter] public string? Fill { get; set; }

    /// <summary>The shape. Use <c>"round"</c> for an increased corner radius.</summary>
    [Parameter] public string? Shape { get; set; }

    /// <summary>If true, the user cannot modify the value.</summary>
    [Parameter] public bool Readonly { get; set; }

    /// <summary>If true, the user cannot interact with the input.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>If true, a clear icon appears while there is a value; clicking it clears the input.</summary>
    [Parameter] public bool ClearInput { get; set; }

    /// <summary>The icon to use for the clear button. Defaults to close-circle (ios) / close-sharp (md).</summary>
    [Parameter] public string? ClearInputIcon { get; set; }

    /// <summary>If true, a character counter is shown below the field. Requires <see cref="Maxlength"/>.</summary>
    [Parameter] public bool Counter { get; set; }

    /// <summary>The maximum number of characters. Used by the counter and passed to the native control.</summary>
    [Parameter] public int? Maxlength { get; set; }

    /// <summary>Helper text displayed below the input when no error is present.</summary>
    [Parameter] public string? HelperText { get; set; }

    /// <summary>Error text displayed below the input when the control is invalid.</summary>
    [Parameter] public string? ErrorText { get; set; }

    /// <summary>Form field name marker.</summary>
    [Parameter] public string? Name { get; set; }

    /// <summary>Content shown at the leading edge of the input.</summary>
    [Parameter] public RenderFragment? StartSlot { get; set; }

    /// <summary>Content shown at the trailing edge of the input.</summary>
    [Parameter] public RenderFragment? EndSlot { get; set; }

    private string _labelWrapperClass = "label-text-wrapper";
    private string _clearIcon = Ionicons.CloseSharp;
    private string _counterText = string.Empty;

    private bool HasValue => !string.IsNullOrEmpty(Value);
    private bool HasLabel => !string.IsNullOrEmpty(Label);
    private bool HasBottomContent =>
        !string.IsNullOrEmpty(HelperText) || !string.IsNullOrEmpty(ErrorText) || ShowCounter;
    private bool ShowCounter => Counter && Maxlength is not null;
    private bool ShowClearButton => ClearInput && HasValue && !Readonly && !Disabled;
    // Ionic only draws the md highlight bar when not using the outline fill (in the tests the
    // input is not hosted inside an ion-item, so the in-item suppression does not apply here).
    private bool ShowHighlight => Mode == "md" && Fill != "outline";

    protected override void OnParametersSet()
    {
        var placement = NormalizeToken(LabelPlacement, "start");

        ClassMapper
            .Clear()
            .Add(Class)
            .Add(Mode)
            .Add("ion-input")
            .Add($"input-label-placement-{placement}")
            .If(HasValue, "has-value")
            .If(Readonly, "input-readonly")
            .If(Disabled, "input-disabled")
            .AddValue(Fill, "input-fill-")
            .AddValue(Shape, "input-shape-")
            .If(!string.IsNullOrWhiteSpace(Color), "ion-color")
            .AddColor(Color);

        _labelWrapperClass = HasLabel
            ? "label-text-wrapper"
            : "label-text-wrapper label-text-wrapper-hidden";

        _clearIcon = ClearInputIcon ?? (Mode == "ios" ? Ionicons.CloseCircle : Ionicons.CloseSharp);

        // Default counter formatter: "{length} / {maxlength}" (port of input.utils getCounterText).
        if (ShowCounter)
        {
            var length = Value?.Length ?? 0;
            _counterText = $"{length} / {Maxlength}";
        }
    }

    /// <summary>
    /// After the subtree is built, wire the native input's value/placeholder/type/disabled state.
    /// RenderTreeBuilder only maps <c>type</c> for a native <c>&lt;input&gt;</c>, so the remaining
    /// attributes are applied here (the same pattern IonCheckbox / IonSelect use).
    /// </summary>
    public override Element Build()
    {
        var root = base.Build();

        if (root.FindByClass("native-input").FirstOrDefault() is InputElement input)
        {
            input.Type = MapType(Type);
            input.Value = Value;
            input.Placeholder = Placeholder;
            if (Disabled) input.SetState(ElementState.Disabled);
        }

        return root;
    }

    private async Task HandleInput(InputEventArgs args)
    {
        if (Disabled || Readonly) return;

        var next = args.Data;
        if (Value != next)
        {
            Value = next;
            await ValueChanged.InvokeAsync(next);
        }

        await OnInput.InvokeAsync(next);
    }

    private async Task HandleChange(ChangeEventArgs args)
    {
        if (Disabled || Readonly) return;

        var next = args.NewValue ?? (args.Target as InputElement)?.Value;
        if (Value != next)
        {
            Value = next;
            await ValueChanged.InvokeAsync(next);
        }

        await OnChange.InvokeAsync(next);
    }

    private async Task HandleClearClick(MouseEventArgs args)
    {
        if (Disabled || Readonly) return;

        args.StopPropagation();

        if (HasValue)
        {
            Value = string.Empty;
            await ValueChanged.InvokeAsync(Value);
            await OnInput.InvokeAsync(Value);
        }
    }

    // Ionic stops propagation when the label itself is clicked so the click is not double-counted;
    // clicking the native input focuses it directly.
    private void HandleLabelClick(MouseEventArgs args)
    {
        if (args.Target == args.CurrentTarget)
        {
            args.StopPropagation();
        }
    }

    // Map the Ionic type string to the nearest Miko InputType. email/tel/url/number/date have no
    // native Miko equivalent, so they render as a plain text field.
    private static InputType MapType(string? type) => type?.ToLowerInvariant() switch
    {
        "password" => InputType.Password,
        "search" => InputType.Search,
        _ => InputType.Text,
    };

    private static string NormalizeToken(string? value, string fallback)
        => string.IsNullOrWhiteSpace(value) ? fallback : value.ToLowerInvariant();
}
