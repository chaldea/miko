@namespace Miko.Ionic.Components
@inherits IonicComponentBase
@* Mirrors Ionic's <ion-accordion>:
   <ion-accordion class="{mode} accordion-expanded|collapsed accordion-disabled? ...">
     <div id="header" part="header"> <slot name="header" /> </div>      <!-- HeaderSlot: an ion-item -->
     <div id="content" part="content">
       <div id="content-wrapper"> <slot name="content" /> </div>        <!-- ContentSlot -->
     </div>
   </ion-accordion>
   The header carries the click handler that requests a toggle from the enclosing group. Ionic slots
   a chevron toggle icon into the header ion-item at runtime (slotToggleIcon); we render it directly
   in the header wrapper as an .ion-accordion-toggle-icon. Expanded state comes from the group's
   cascaded value set. When collapsed the content is display:none (see AccordionStyles). *@
<div class="@ClassMapper.Class" style="@Style">
    <div id="@_headerId" class="accordion-header" @onclick="ToggleExpandedAsync">
        @HeaderSlot
        <span class="ion-accordion-toggle-icon accordion-toggle-icon-@_toggleIconSlot">
            <IonIcon Icon="@ToggleIcon" />
        </span>
    </div>
    <div id="@_contentId" class="accordion-content">
        <div class="accordion-content-wrapper">
            @ContentSlot
        </div>
    </div>
</div>

@code {
    /// <summary>This accordion's value; matches the group's expanded value(s) to show its content.
    /// Defaults to an autogenerated value when unset (mirrors Ionic).</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>If true, this accordion is dimmed and non-interactive.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>If true, this accordion is non-interactive but not dimmed.</summary>
    [Parameter] public bool Readonly { get; set; }

    /// <summary>The toggle icon rotated on expand/collapse. Defaults to a downward chevron.</summary>
    [Parameter] public string ToggleIcon { get; set; } = Ionicons.ChevronDown;

    /// <summary>Slot in the header item for the toggle icon: <c>"start"</c> or <c>"end"</c>.
    /// Falls back to the group's setting, then <c>"end"</c>.</summary>
    [Parameter] public string? ToggleIconSlot { get; set; }

    /// <summary>The header row content (Ionic <c>slot="header"</c>), typically an <c>IonItem</c>.</summary>
    [Parameter] public RenderFragment? HeaderSlot { get; set; }

    /// <summary>The collapsible content (Ionic <c>slot="content"</c>).</summary>
    [Parameter] public RenderFragment? ContentSlot { get; set; }

    /// <summary>Selection/behavior state supplied by the enclosing <see cref="IonAccordionGroup"/>.</summary>
    [CascadingParameter] public IonAccordionGroupContext? GroupContext { get; set; }

    private static int _idCounter;
    private readonly int _instanceId = _idCounter++;
    private string _headerId = string.Empty;
    private string _contentId = string.Empty;
    private string _toggleIconSlot = "end";
    private string _value = string.Empty;

    /// <summary>True when this accordion's value is in the group's expanded set.</summary>
    public bool Expanded { get; private set; }

    protected override void OnParametersSet()
    {
        // Ionic autogenerates `ion-accordion-{n}` when no value is set.
        _value = string.IsNullOrEmpty(Value) ? $"ion-accordion-{_instanceId}" : Value!;
        _headerId = $"accordion-header-{_instanceId}";
        _contentId = $"accordion-content-{_instanceId}";

        _toggleIconSlot = ToggleIconSlot
            ?? GroupContext?.ToggleIconSlot
            ?? "end";

        var groupDisabled = GroupContext?.Disabled ?? false;
        var groupReadonly = GroupContext?.Readonly ?? false;
        var disabled = Disabled || groupDisabled;
        var readonly_ = Readonly || groupReadonly;

        Expanded = GroupContext?.IsExpanded(_value) ?? false;

        ClassMapper
            .Clear()
            .Add(Class)
            .Add(Mode)
            .Add("ion-accordion")
            .Add(Expanded ? "accordion-expanded" : "accordion-collapsed")
            .If(disabled, "accordion-disabled")
            .If(readonly_, "accordion-readonly");
    }

    /// <summary>
    /// Header click: ask the group to toggle this accordion. Mirrors <c>accordion.tsx</c>
    /// <c>toggleExpanded()</c> — no-op when disabled/readonly; otherwise requests expand when
    /// currently collapsed, collapse when expanded, and lets the group decide.
    /// </summary>
    private async Task ToggleExpandedAsync(MouseEventArgs _)
    {
        if (GroupContext is null) return;

        var groupDisabled = GroupContext.Disabled;
        var groupReadonly = GroupContext.Readonly;
        if (Disabled || Readonly || groupDisabled || groupReadonly) return;

        await GroupContext.RequestToggle.InvokeAsync((_value, !Expanded));
    }
}
