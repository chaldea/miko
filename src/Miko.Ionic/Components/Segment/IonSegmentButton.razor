@namespace Miko.Ionic.Components
@inherits IonicComponentBase
@* Mirrors Ionic's <ion-segment-button> host structure:
   <ion-segment-button>            <!-- host: flex column, the checked/label-only/etc. classes -->
     <button class="button-native"> <!-- the clickable surface; flex-grows to fill the host -->
       <span class="button-inner">  <!-- centers the slotted content -->
         <slot />                   <!-- ion-label / ion-icon -->
       </span>
     </button>
     <div class="segment-button-indicator"> <!-- SIBLING of the button, not inside it -->
       <div class="segment-button-indicator-background"></div>
     </div>
   </ion-segment-button>
   The indicator is the checked-state overlay: md a 2px primary underline bar, ios a full-height
   light pill behind the label. Keeping it a sibling (not inside the button) is what lets the
   label sit correctly centered in the button with its 12px margin — the indicator no longer
   participates in the button's flex flow. *@
<div class="@ClassMapper.Class" style="@Style">
    <button class="button-native" @onclick="HandleClick">
        <span class="button-inner">
            @ChildContent
        </span>
    </button>
    <div class="segment-button-indicator">
        <div class="segment-button-indicator-background"></div>
    </div>
</div>

@code {
    /// <summary>This button's value; becomes the segment's selected value when tapped.</summary>
    [Parameter] public string Value { get; set; } = string.Empty;

    /// <summary>Id of the <see cref="IonSegmentContent"/> this button activates in a segment view.</summary>
    [Parameter] public string? ContentId { get; set; }

    /// <summary>When true this individual button is dimmed and non-interactive.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>
    /// Content arrangement (Ionic <c>layout</c>: <c>"icon-top"</c>, <c>"icon-start"</c>, …).
    /// Kept for API parity; emitted as a marker class only in this base port.
    /// </summary>
    [Parameter] public string? Layout { get; set; }

    /// <summary>Selection/select callback supplied by the enclosing <see cref="IonSegment"/>.</summary>
    [CascadingParameter] public IonSegmentContext? SegmentContext { get; set; }

    /// <summary>True when this button's value matches the segment's selected value.</summary>
    public bool Selected { get; private set; }

    protected override void OnParametersSet()
    {
        Selected = SegmentContext is not null && SegmentContext.Value == Value;

        ClassMapper
            .Clear()
            .Add(Class)
            .Add(Mode)
            .Add("ion-segment-button")
            .If(Selected, "segment-button-checked")
            .If(Disabled, "segment-button-disabled")
            .AddValue(Layout, "segment-button-layout-");
    }

    /// <summary>
    /// After the tree is built, stamp the content markers Ionic derives from the slotted children:
    /// <c>segment-button-has-label</c>/<c>-icon</c> and the <c>-label-only</c>/<c>-icon-only</c>
    /// variants. Ionic resolves these at render via <c>querySelector</c>; here we scan the built
    /// subtree for an <c>ion-label</c>/<c>ion-icon</c> descendant and append the classes to the
    /// host button. The <c>-has-label-only</c> marker drives the md label margin rule
    /// (<c>segment-button.md.scss</c>).
    /// </summary>
    public override Element Build()
    {
        var root = base.Build();
        bool hasLabel = root.FindByClass("ion-label").Count > 0;
        bool hasIcon = root.FindByClass("ion-icon").Count > 0;

        if (hasLabel) root.Class += " segment-button-has-label";
        if (hasIcon) root.Class += " segment-button-has-icon";
        if (hasLabel && !hasIcon) root.Class += " segment-button-has-label-only";
        if (hasIcon && !hasLabel) root.Class += " segment-button-has-icon-only";

        return root;
    }

    private async Task HandleClick(MouseEventArgs _)
    {
        if (Disabled || SegmentContext is null) return;
        await SegmentContext.Select.InvokeAsync(Value);
    }
}
