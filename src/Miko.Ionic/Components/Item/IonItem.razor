@namespace Miko.Ionic.Components
@inherits IonicComponentBase
<div class="@ClassMapper.Class" style="@Style">
    @ChildContent
</div>

@code {
    /// <summary>
    /// Divider behavior. <c>"none"</c> drops the bottom divider; any other value (or null)
    /// keeps the default hairline. Mirrors Ionic's <c>lines</c> attribute on <c>ion-item</c>.
    /// </summary>
    [Parameter] public string? Lines { get; set; }

    protected override void OnParametersSet()
    {
        ClassMapper
            .Clear()
            .Add(ClassName)
            .Add(Mode)
            .Add("ion-item")
            .If(string.Equals(Lines, "none", StringComparison.OrdinalIgnoreCase), "ion-item-lines-none");
    }
}
