@namespace Miko.Ionic.Components
@inherits IonicComponentBase
@* Mirrors Ionic's <ion-item-options>: the container holding the swipe-reveal action buttons for
   an <ion-item-sliding>. It is anchored to one edge (Side "end" default, or "start") and sits
   off-screen until the sliding row is opened. It cascades its Side down to its <ion-item-option>
   children so they (and the stylesheet) know which edge they belong to. *@
<div class="@ClassMapper.Class" style="@Style">
    <CascadingValue TValue="string" Name="ItemOptionsSide" Value="@_side">
        @ChildContent
    </CascadingValue>
</div>

@code {
    /// <summary>Edge these options are anchored to: <c>"end"</c> (default) or <c>"start"</c>.
    /// Mirrors Ionic's <c>side</c> attribute on <c>ion-item-options</c>.</summary>
    [Parameter] public string Side { get; set; } = "end";

    private string _side = "end";

    protected override void OnParametersSet()
    {
        _side = string.Equals(Side, "start", StringComparison.OrdinalIgnoreCase) ? "start" : "end";

        ClassMapper
            .Clear()
            .Add(Class)
            .Add(Mode)
            .Add("ion-item-options")
            // Ionic-internal styling classes from item-options.tsx: `item-options-{mode}` and
            // `item-options-{start|end}` (mapped directly from the side — end→item-options-end).
            // We also keep our own `ion-item-options-{side}` which the reveal/transform rules in
            // ItemStyles target.
            .Add($"item-options-{Mode}")
            .Add($"ion-item-options-{_side}")
            .Add($"item-options-{_side}");
    }
}
