@namespace Miko.Ionic.Components
@inherits IonicComponentBase
<div class="@ClassMapper.Class" style="@Style">
    @ChildContent
</div>

@code {
    /// <summary>Named palette color (Ionic <c>color</c>): <c>"primary"</c>, <c>"danger"</c>, ... .</summary>
    [Parameter] public string? Color { get; set; }

    /// <summary>When true, renders the outline chip variant.</summary>
    [Parameter] public bool Outline { get; set; }

    /// <summary>When true, the chip is dimmed and non-interactive.</summary>
    [Parameter] public bool Disabled { get; set; }

    protected override void OnParametersSet()
    {
        ClassMapper
            .Clear()
            .Add(ClassName)
            .Add(Mode)
            .Add("ion-chip")
            .Add("ion-activatable")
            .If(Outline, "chip-outline")
            .If(Disabled, "chip-disabled")
            .If(!string.IsNullOrWhiteSpace(Color), "ion-color")
            .AddColor(Color);
    }
}
