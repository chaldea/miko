<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Local feed that hosts the Miko packages. Adjust the path if your feed lives elsewhere. -->
    <add key="miko-local" value="F:\.nuget\local" />
  </packageSources>
  <!--
    Map the Miko packages to the local feed. This is additive to any source mapping
    configured globally, so packages from nuget.org keep resolving as usual.
  -->
  <packageSourceMapping>
    <packageSource key="miko-local">
      <package pattern="Miko*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
