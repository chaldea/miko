@page "/"
@namespace MikoMultiplatformApp.Pages
@inject Miko.Animation.AnimationManager Animations

@* Sidemenu (overlay drawer) layout with slide/fade animation. IonApp lays out the page and
   the menu as siblings; the menu is authored after the page so the reverse-document-order
   hit-test reaches the (full-screen) menu host first. IonMenu owns its own backdrop and the
   deferred-unmount timing — the page only flips _menuOpen. The AnimationManager is passed
   down because nested components don't receive DI injection. *@
<IonApp>
    <IonPage>
        <IonHeader>
            <IonToolbar>
                <IonButtons Slot="start">
                    <IonMenuButton OnClick="OpenMenu" />
                </IonButtons>
                <IonTitle>Inbox</IonTitle>
            </IonToolbar>
        </IonHeader>

        <IonContent Fullscreen="true">
            <div class="demo-content">
                <p>This is the sidemenu layout demo.</p>
                <p>Tap the menu button in the top-left to slide the navigation drawer in over
                   the page. Tap the dimmed backdrop to slide it back out.</p>
            </div>
        </IonContent>
    </IonPage>

    <IonMenu IsOpen="_menuOpen" Side="start" Type="overlay" OnClose="CloseMenu" Animations="Animations">
        <IonContent>
            <IonList Id="inbox-list">
                <IonListHeader>Inbox</IonListHeader>
                @foreach (var item in _pages)
                {
                    <IonItem Lines="none">
                        <IonIcon Icon="@item.Icon" />
                        <IonLabel>@item.Title</IonLabel>
                    </IonItem>
                }
            </IonList>
        </IonContent>
    </IonMenu>
</IonApp>

@code {
    private bool _menuOpen;

    private readonly MenuPage[] _pages =
    {
        new("Inbox", Ionicons.MailOutline),
        new("Outbox", Ionicons.PaperPlaneOutline),
        new("Favorites", Ionicons.HeartOutline),
        new("Archived", Ionicons.ArchiveOutline),
        new("Trash", Ionicons.TrashOutline),
        new("Spam", Ionicons.WarningOutline),
    };

    // The click handlers live in IonMenuButton / IonMenu (their EventCallbacks re-render those
    // child components, not this page), so call StateHasChanged() here — this page owns
    // _menuOpen and renders IonMenu — to drive the open/close animation.
    private void OpenMenu()
    {
        _menuOpen = true;
        StateHasChanged();
    }

    private void CloseMenu()
    {
        _menuOpen = false;
        StateHasChanged();
    }

    private readonly record struct MenuPage(string Title, string Icon);
}
