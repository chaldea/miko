{
  "$schema": "http://json.schemastore.org/template",
  "author": "Miko",
  "classifications": [ "Miko", "Razor", "Multiplatform", "Desktop", "Android", "iOS", "Empty" ],
  "identity": "Miko.Razor.Multiplatform.Empty",
  "name": "Miko Razor Multiplatform App (Empty)",
  "shortName": "miko-multiplatform",
  "description": "An empty Miko cross-platform application (Desktop/Android/iOS) using Razor components, rendered with SkiaSharp.",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "MikoMultiplatformApp",
  "preferNameDirectory": true,
  "symbols": {
    "layout": {
      "type": "parameter",
      "datatype": "choice",
      "description": "Initial UI layout to scaffold.",
      "defaultValue": "blank",
      "choices": [
        { "choice": "blank",    "description": "An empty page (default)." },
        { "choice": "sidemenu", "description": "Ionic side-menu drawer over a content page." },
        { "choice": "tabs",     "description": "Ionic bottom tab bar with three routed tab pages." }
      ]
    },
    "useBlank":    { "type": "computed", "value": "(layout == \"blank\")" },
    "useSidemenu": { "type": "computed", "value": "(layout == \"sidemenu\")" },
    "useTabs":     { "type": "computed", "value": "(layout == \"tabs\")" },
    "useIonic":    { "type": "computed", "value": "(layout == \"sidemenu\" || layout == \"tabs\")" }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "**/*.user",
            "nuget.config"
          ]
        },
        {
          "condition": "(useBlank)",
          "exclude": [
            "**/MainLayout.tabs.razor",
            "**/MainLayout.sidemenu.razor",
            "**/GlobalStyles.tabs.cs",
            "**/GlobalStyles.sidemenu.cs",
            "**/_Imports.tabs.razor",
            "**/_Imports.sidemenu.razor",
            "**/Pages/Home.sidemenu.razor",
            "**/Pages/Tab1Page.razor",
            "**/Pages/Tab2Page.razor",
            "**/Pages/Tab3Page.razor"
          ],
          "rename": {
            "MikoMultiplatformApp/MainLayout.blank.razor": "MikoMultiplatformApp/MainLayout.razor",
            "MikoMultiplatformApp/GlobalStyles.blank.cs":  "MikoMultiplatformApp/GlobalStyles.cs",
            "MikoMultiplatformApp/Pages/Home.blank.razor": "MikoMultiplatformApp/Pages/Home.razor"
          }
        },
        {
          "condition": "(useTabs)",
          "exclude": [
            "**/MainLayout.blank.razor",
            "**/MainLayout.sidemenu.razor",
            "**/GlobalStyles.blank.cs",
            "**/GlobalStyles.sidemenu.cs",
            "**/_Imports.sidemenu.razor",
            "**/Pages/Home.blank.razor",
            "**/Pages/Home.sidemenu.razor"
          ],
          "rename": {
            "MikoMultiplatformApp/MainLayout.tabs.razor": "MikoMultiplatformApp/MainLayout.razor",
            "MikoMultiplatformApp/GlobalStyles.tabs.cs":  "MikoMultiplatformApp/GlobalStyles.cs",
            "MikoMultiplatformApp/_Imports.tabs.razor":   "MikoMultiplatformApp/_Imports.razor"
          }
        },
        {
          "condition": "(useSidemenu)",
          "exclude": [
            "**/MainLayout.blank.razor",
            "**/MainLayout.tabs.razor",
            "**/GlobalStyles.blank.cs",
            "**/GlobalStyles.tabs.cs",
            "**/_Imports.tabs.razor",
            "**/Pages/Home.blank.razor",
            "**/Pages/Tab1Page.razor",
            "**/Pages/Tab2Page.razor",
            "**/Pages/Tab3Page.razor"
          ],
          "rename": {
            "MikoMultiplatformApp/MainLayout.sidemenu.razor": "MikoMultiplatformApp/MainLayout.razor",
            "MikoMultiplatformApp/GlobalStyles.sidemenu.cs":  "MikoMultiplatformApp/GlobalStyles.cs",
            "MikoMultiplatformApp/_Imports.sidemenu.razor":   "MikoMultiplatformApp/_Imports.razor",
            "MikoMultiplatformApp/Pages/Home.sidemenu.razor": "MikoMultiplatformApp/Pages/Home.razor"
          }
        }
      ]
    }
  ]
}
