{
  "$schema": "http://json.schemastore.org/template",
  "author": "Miko",
  "classifications": [ "Miko", "Razor", "WinUI", "Desktop", "Empty" ],
  "identity": "Miko.Razor.WinUI.Empty",
  "name": "Miko Razor WinUI App (Empty)",
  "shortName": "miko-razor",
  "description": "An empty Miko desktop application using Razor components, rendered with SkiaSharp.",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "MikoRazorApp",
  "preferNameDirectory": true,
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        {
          "choice": "net10.0",
          "description": ".NET 10.0"
        }
      ],
      "replaces": "net10.0",
      "defaultValue": "net10.0"
    },
    "layout": {
      "type": "parameter",
      "datatype": "choice",
      "description": "Initial UI layout to scaffold.",
      "defaultValue": "blank",
      "choices": [
        { "choice": "blank",    "description": "An empty page (default)." },
        { "choice": "sidemenu", "description": "Ionic side-menu drawer over a content page." },
        { "choice": "tabs",     "description": "Ionic bottom tab bar with three routed tab pages." }
      ]
    },
    "displayName": {
      "type": "parameter",
      "datatype": "string",
      "description": "Human-readable application display name (window title). Defaults to the project name.",
      "defaultValue": "",
      "replaces": ""
    },
    "appDisplayName": {
      "type": "generated",
      "generator": "coalesce",
      "parameters": {
        "sourceVariableName": "displayName",
        "fallbackVariableName": "name"
      },
      "replaces": "Miko Razor App"
    },
    "useBlank":    { "type": "computed", "value": "(layout == \"blank\")" },
    "useSidemenu": { "type": "computed", "value": "(layout == \"sidemenu\")" },
    "useTabs":     { "type": "computed", "value": "(layout == \"tabs\")" },
    "useIonic":    { "type": "computed", "value": "(layout == \"sidemenu\" || layout == \"tabs\")" },
    "agent": {
      "type": "parameter",
      "datatype": "choice",
      "description": "Scaffold AI-agent config and Miko docs for the given assistant.",
      "defaultValue": "none",
      "choices": [
        { "choice": "none",   "description": "No agent config (default)." },
        { "choice": "claude", "description": "Claude Code: .claude/, .miko/ docs, CLAUDE.md." },
        { "choice": "codex",  "description": "Codex: .codex/, .miko/ docs, AGENTS.md." },
        { "choice": "cursor", "description": "Cursor: .cursor/, .miko/ docs." }
      ]
    },
    "agentNone":   { "type": "computed", "value": "(agent == \"none\")" },
    "agentClaude": { "type": "computed", "value": "(agent == \"claude\")" },
    "agentCodex":  { "type": "computed", "value": "(agent == \"codex\")" },
    "agentCursor": { "type": "computed", "value": "(agent == \"cursor\")" }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "bin/**",
            "obj/**",
            "**/*.user",
            "nuget.config",
            ".mcp.json",
            ".claude/settings.local.json"
          ]
        },
        {
          "condition": "(agentNone)",
          "exclude": [
            ".miko/**",
            ".claude/**",
            ".codex/**",
            ".cursor/**",
            "CLAUDE.md",
            "AGENTS.md"
          ]
        },
        {
          "condition": "(!agentClaude)",
          "exclude": [ ".claude/**", "CLAUDE.md" ]
        },
        {
          "condition": "(!agentCodex)",
          "exclude": [ ".codex/**", "AGENTS.md" ]
        },
        {
          "condition": "(!agentCursor)",
          "exclude": [ ".cursor/**" ]
        },
        {
          "condition": "(useBlank)",
          "exclude": [
            "MainLayout.tabs.razor",
            "MainLayout.sidemenu.razor",
            "GlobalStyles.tabs.cs",
            "GlobalStyles.sidemenu.cs",
            "_Imports.tabs.razor",
            "_Imports.sidemenu.razor",
            "Pages/Home.sidemenu.razor",
            "Pages/Tab1Page.razor",
            "Pages/Tab2Page.razor",
            "Pages/Tab3Page.razor"
          ],
          "rename": {
            "MainLayout.blank.razor": "MainLayout.razor",
            "GlobalStyles.blank.cs":  "GlobalStyles.cs",
            "Pages/Home.blank.razor": "Pages/Home.razor"
          }
        },
        {
          "condition": "(useTabs)",
          "exclude": [
            "MainLayout.blank.razor",
            "MainLayout.sidemenu.razor",
            "GlobalStyles.blank.cs",
            "GlobalStyles.sidemenu.cs",
            "_Imports.sidemenu.razor",
            "Pages/Home.blank.razor",
            "Pages/Home.sidemenu.razor"
          ],
          "rename": {
            "MainLayout.tabs.razor": "MainLayout.razor",
            "GlobalStyles.tabs.cs":  "GlobalStyles.cs",
            "_Imports.tabs.razor":   "_Imports.razor"
          }
        },
        {
          "condition": "(useSidemenu)",
          "exclude": [
            "MainLayout.blank.razor",
            "MainLayout.tabs.razor",
            "GlobalStyles.blank.cs",
            "GlobalStyles.tabs.cs",
            "_Imports.tabs.razor",
            "Pages/Home.blank.razor",
            "Pages/Tab1Page.razor",
            "Pages/Tab2Page.razor",
            "Pages/Tab3Page.razor"
          ],
          "rename": {
            "MainLayout.sidemenu.razor": "MainLayout.razor",
            "GlobalStyles.sidemenu.cs":  "GlobalStyles.cs",
            "_Imports.sidemenu.razor":   "_Imports.razor",
            "Pages/Home.sidemenu.razor": "Pages/Home.razor"
          }
        }
      ]
    }
  ]
}
